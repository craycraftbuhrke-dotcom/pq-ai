FROM comfyui-local:latest

WORKDIR /app
ENV NODE_ENV=production
# 前端容器监听端口，默认 80（nginx 惯例）
ENV PORT=80
ENV LISTEN_HOST=0.0.0.0
COPY .runtime/node /usr/local/bin/node
COPY .next/standalone ./
COPY .next/static ./apps/web/.next/static
COPY public ./apps/web/public

ENTRYPOINT []
EXPOSE 80
CMD ["sh", "-c", "HOSTNAME=\"${LISTEN_HOST:-0.0.0.0}\" PORT=\"${PORT:-80}\" node apps/web/server.js"]
