FROM comfyui-local:latest

WORKDIR /app
COPY .runtime/site-packages /opt/pq-ai/site-packages
COPY pyproject.toml ./
COPY app ./app

ENV PYTHONPATH=/opt/pq-ai/site-packages:/app
ENTRYPOINT []
EXPOSE 8000
CMD ["sh", "-c", "if [ \"$SEED_DEMO_DATA\" = \"true\" ]; then python3 -m app.db.seed_demo; fi && python3 -m uvicorn app.main:app --host 0.0.0.0 --port 8000"]
