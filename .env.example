# Build-time image inputs
NODE_IMAGE=node:22-alpine
PYTHON_IMAGE=python:3.11-slim
MYSQL_IMAGE=mysql:8.4

# MySQL runtime inputs
MYSQL_DATABASE=<mysql-database-name>
MYSQL_USER=<mysql-application-user>
MYSQL_PASSWORD=<runtime-secret>
MYSQL_ROOT_PASSWORD=<runtime-secret>
MYSQL_PORT=3306

# Backend runtime inputs
APP_NAME=PQ-AI API
API_PREFIX=/api/v1
DATABASE_URL=<runtime-secret-sqlalchemy-database-url>
API_CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:8080
# 默认启用登录、RBAC 和审计；只有隔离测试可显式关闭。
API_AUTH_ENABLED=true
AUTH_ENABLED=true
NEXT_PUBLIC_AUTH_ENABLED=true
ALLOW_SELF_REGISTRATION=false
NEXT_PUBLIC_ALLOW_SELF_REGISTRATION=false
SEED_ON_STARTUP=false
SESSION_TTL_MINUTES=720
API_HOST=0.0.0.0
API_PORT=8000
API_PUBLISH_PORT=8000

# Frontend runtime and build inputs
NODE_ENV=production
FRONTEND_HOSTNAME=0.0.0.0
# 前端容器内监听端口（Next.js standalone server），默认 80（nginx 惯例）；如与宿主机 80 冲突可改 8080
FRONTEND_PORT=80
# 宿主机映射端口，正式部署建议 80；本地开发可改 8080 避开系统端口冲突
FRONTEND_PUBLISH_PORT=80
API_URL=http://api:8000/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
BODY_MODEL_MAX_UPLOAD_BYTES=268435456
BODY_MODEL_UPLOAD_SESSION_TTL_MS=86400000
# K8s 中挂载 RWX PVC；本地留空时与 apps/web/public 共用。
WEB_RUNTIME_ASSET_DIR=
BULK_IMPORT_MAX_BYTES=52428800
FILE_IMPORT_MAX_BYTES=52428800

# Experience image names, only needed by docker-compose.experience.yml
API_IMAGE=pq-ai-api:experience
FRONTEND_IMAGE=pq-ai-web:experience
